{
  "build": {
    "builder": "dockerfile"
  },
  "deploy": {
    "restartPolicyMaxRetries": 5,
    "restartPolicyWindowSeconds": 600,
    "healthcheckPath": "/health",
    "healthcheckTimeout": 300,
    "startCommand": "cd apps/api && sh start.sh"
  },
  "environment": {
    "NODE_ENV": "production"
  }
}
