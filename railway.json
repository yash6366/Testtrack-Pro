{
  "build": {
    "builder": "dockerfile"
  },
  "deploy": {
    "startCommand": "pnpm --filter api start",
    "restartPolicyMaxRetries": 5,
    "restartPolicyWindowSeconds": 600,
    "healthcheckPath": "/api/health",
    "healthcheckTimeout": 30
  },
  "environment": {
    "NODE_ENV": "production"
  }
}
