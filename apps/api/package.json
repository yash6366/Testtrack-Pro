{
  "name": "api",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "node --watch src/server.js",
    "build": "echo 'No build needed for Node.js'",
    "start": "node src/server.js",
    "db:migrate": "node scripts/migrate-with-baseline.js",
    "db:push": "prisma db push --accept-data-loss",
    "db:generate": "prisma generate",
    "db:setup": "pnpm run db:generate && pnpm run db:migrate",
    "lint": "eslint .",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@fastify/cors": "^8.4.0",
