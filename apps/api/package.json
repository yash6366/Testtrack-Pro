    "@fastify/swagger": "^8.15.0",
    "@fastify/swagger-ui": "^4.2.0",
    "@fastify/websocket": "^8.3.1",
    "@prisma/client": "^5.7.0",
    "@sentry/node": "^7.99.0",
    "@shared/types": "workspace:*",
    "@socket.io/redis-adapter": "^8.3.0",
    "@upstash/redis": "^1.36.2",
    "bcryptjs": "^2.4.3",
    "cloudinary": "^2.5.0",
    "exceljs": "^4.4.0",
    "fastify": "^4.25.0",
    "i18next": "^25.8.13",
